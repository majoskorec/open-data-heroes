{% set prevDeclaration = prevDeclaration|default(null) %}

<section id="year-{{ declaration.year }}" class="section-anchor mb-4">
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h2 class="h3 mb-0">Rok {{ declaration.year }}</h2>
                </div>

                <div class="text-body-secondary mt-2">
                    ID oznámenia #{{ declaration.externalId }}
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 align-self-start">
                <span class="badge rounded-pill text-bg-light border">
                    {{ declaration.declarationRealEstate|default([])|length }} nehn.
                </span>
                <span class="badge rounded-pill text-bg-light border">
                    {{ declaration.declarationMovableAssets|default([])|length }} hnut.
                </span>
                <span class="badge rounded-pill text-bg-light border">
                    {{ declaration.declarationValuableRight|default([])|length }} práva
                </span>
                <span class="badge rounded-pill text-bg-light border">
                    {{ declaration.declarationLiabilities|default([])|length }} záväzky
                </span>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row g-4 mb-4">
            <div class="col-12 col-lg-6">
                <div class="card h-100 border">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Príjmy a sumár</h3>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <div class="small text-body-secondary mb-1">Príjem z verejnej funkcie</div>
                                    <div class="fs-4 fw-semibold">
                                        {% if declaration.declarationIncome and declaration.declarationIncome.publicFunctionIncome %}
                                            {{ declaration.declarationIncome.publicFunctionIncome|number_format(2, '.', ' ') }} €
                                        {% else %}
                                            —
                                        {% endif %}
                                        <twig:PublicFunctionIncomeDiff
                                            from="{{ prevDeclaration.declarationIncome|default(null) }}"
                                            to="{{ declaration.declarationIncome }}"
                                        />
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <div class="small text-body-secondary mb-1">Iné príjmy</div>
                                    <div class="fs-4 fw-semibold">
                                        {% if declaration.declarationIncome and declaration.declarationIncome.otherIncome %}
                                            {{ declaration.declarationIncome.otherIncome|number_format(2, '.', ' ') }} €
                                        {% else %}
                                            —
                                        {% endif %}
                                        <twig:OtherIncomeDiff
                                            from="{{ prevDeclaration.declarationIncome|default(null) }}"
                                            to="{{ declaration.declarationIncome }}"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="card border">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Verejné funkcie</h3>
                        {% if declaration.declarationPublicFunction|default([])|length > 0 %}
                            <div class="d-flex flex-wrap gap-2">
                                {% for function in declaration.declarationPublicFunction %}
                                    <span class="badge rounded-pill text-bg-light border px-3 py-2">
                                        {{ function.name }}
                                    </span>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-body-secondary mb-0">Bez evidovaných funkcií.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="card border mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="h5 mb-0">Nehnuteľnosti</h3>
                    <span class="badge rounded-pill text-bg-light border">
                        {{ declaration.declarationRealEstate|default([])|length }}
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Typ</th>
                            <th>Katastrálne územie</th>
                            <th>LV</th>
                            <th>Podiel</th>
                            <th>Odhad / hodnota</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in declaration.declarationRealEstate|default([]) %}
                            <tr>
                                <td>{{ item.assetType ?: '—' }}</td>
                                <td>{{ item.cadastralArea ?: '—' }}</td>
                                <td class="font-monospace">{{ item.lvNumber ?: '—' }}</td>
                                <td class="font-monospace">
                                    {% if item.ownershipShare and item.ownershipShare.numerator and item.ownershipShare.denominator %}
                                        {{ item.ownershipShare.numerator }}/{{ item.ownershipShare.denominator }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if item.valuation %}
                                        {% if item.valuation.exactValue %}
                                            <span class="badge text-bg-primary">{{ item.valuation.exactValue|number_format(2, '.', ' ') }} €</span>
                                        {% elseif item.valuation.estimatedLikelyValue %}
                                            <span class="badge text-bg-warning">~ {{ item.valuation.estimatedLikelyValue|number_format(2, '.', ' ') }} €</span>
                                        {% else %}
                                            —
                                        {% endif %}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if item.ancestor %}
                                        {% if item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Added') %}
                                            <span class="badge rounded-pill text-bg-success border">
                                                Nové
                                            </span>
                                        {% elseif item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Decreased') %}
                                            <span class="badge rounded-pill text-bg-warning border">
                                                zníženie podielu
                                            </span>
                                        {% elseif item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Increased') %}
                                            <span class="badge rounded-pill text-bg-success border">
                                                zvýšenie podielu
                                            </span>
                                        {% endif %}
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-body-secondary">Bez evidovaných nehnuteľností.</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card border mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="h5 mb-0">Hnuteľný majetok</h3>
                    <span class="badge rounded-pill text-bg-light border">
                        {{ declaration.declarationMovableAssets|default([])|length }}
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Typ</th>
                            <th>Značka</th>
                            <th>Rok výroby</th>
                            <th>Podiel</th>
                            <th>Odhad / hodnota</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in declaration.declarationMovableAssets|default([]) %}
                            <tr>
                                <td>{{ item.assetType ?: '—' }}</td>
                                <td>{{ item.brand ?: '—' }}</td>
                                <td>{{ item.manufactureYear ?: '—' }}</td>
                                <td class="font-monospace">
                                    {% if item.ownershipShare and item.ownershipShare.numerator and item.ownershipShare.denominator %}
                                        {{ item.ownershipShare.numerator }}/{{ item.ownershipShare.denominator }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if item.valuation %}
                                        {% if item.valuation.exactValue %}
                                            <span class="badge text-bg-primary">{{ item.valuation.exactValue|number_format(2, '.', ' ') }} €</span>
                                        {% elseif item.valuation.estimatedLikelyValue %}
                                            <span class="badge text-bg-warning">~ {{ item.valuation.estimatedLikelyValue|number_format(2, '.', ' ') }} €</span>
                                        {% else %}
                                            —
                                        {% endif %}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    {% if item.ancestor %}
                                        {% if item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Added') %}
                                            <span class="badge rounded-pill text-bg-success border">
                                                Nové
                                            </span>
                                        {% elseif item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Decreased') %}
                                            <span class="badge rounded-pill text-bg-warning border">
                                                zníženie podielu
                                            </span>
                                        {% elseif item.ancestor.getChangeStatus() == constant('App\\Model\\ChangeStatusEnum::Increased') %}
                                            <span class="badge rounded-pill text-bg-success border">
                                                zvýšenie podielu
                                            </span>
                                        {% endif %}
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-body-secondary">Bez evidovaného hnuteľného majetku.</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="card border h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Majetkové práva</h3>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th>Typ</th>
                                    <th>Podiel</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for item in declaration.declarationValuableRight|default([]) %}
                                    <tr>
                                        <td>{{ item.assetType ?: '—' }}</td>
                                        <td class="font-monospace">
                                            {% if item.ownershipShare and item.ownershipShare.numerator and item.ownershipShare.denominator %}
                                                {{ item.ownershipShare.numerator }}/{{ item.ownershipShare.denominator }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-body-secondary">Bez evidovaných majetkových práv.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card border h-100">
                    <div class="card-body">
                        <h3 class="h5 mb-3">Záväzky</h3>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th>Typ</th>
                                    <th>Dátum vzniku</th>
                                    <th>Podiel</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for item in declaration.declarationLiabilities|default([]) %}
                                    <tr>
                                        <td>{{ item.liabilityType ?: '—' }}</td>
                                        <td>{{ item.originatedAt ? item.originatedAt|date('d.m.Y') : '—' }}</td>
                                        <td class="font-monospace">
                                            {% if item.ownershipShare and item.ownershipShare.numerator and item.ownershipShare.denominator %}
                                                {{ item.ownershipShare.numerator }}/{{ item.ownershipShare.denominator }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-body-secondary">Bez evidovaných záväzkov.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</section>
